{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"target": "ESNext",
		"strict": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.svelte",
		"src/app.d.ts"
	]
}
